    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data) {",
                  "        // Priorizar idToken sobre customToken",
                  "        var token = jsonData.data.idToken || jsonData.data.customToken;",
                  "        if (token) {",
                  "            pm.environment.set(\"token\", token);",
                  "            pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "            pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "            if (jsonData.data.firebaseUid) {",
                  "                pm.environment.set(\"firebaseUid\", jsonData.data.firebaseUid);",
                  "            }",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Juan\",\n  \"lastName\": \"Pérez\",\n  \"email\": \"juan@test.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"+521234567890\",\n  \"address\": \"Calle Principal 123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registrar un nuevo usuario con Firebase Auth. Crea el usuario en Firebase Auth y Firestore. Retorna un idToken que se guarda automáticamente. Usa este token en el header Authorization: Bearer {{token}}"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data) {",
                  "        // Priorizar idToken sobre customToken",
                  "        var token = jsonData.data.idToken || jsonData.data.customToken;",
                  "        if (token) {",
                  "            pm.environment.set(\"token\", token);",
                  "            pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "            pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "            if (jsonData.data.firebaseUid) {",
                  "                pm.environment.set(\"firebaseUid\", jsonData.data.firebaseUid);",
                  "            }",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Iniciar sesión con Firebase Auth. Retorna un idToken que se guarda automáticamente en la variable 'token'. Usa este token en el header Authorization: Bearer {{token}}"
          },
          "response": []
        },
        {
          "name": "Login with Google",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.idToken) {",
                  "        // Guardar ID token de Google",
                  "        pm.environment.set(\"token\", jsonData.data.idToken);",
                  "        pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "        pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "        pm.environment.set(\"firebaseUid\", jsonData.data.firebaseUid);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"tu_id_token_de_google_aqui\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login", "google"]
            },
            "description": "Login con Google. Requiere un ID token obtenido del cliente después de hacer login con Google usando Firebase SDK. El token se guarda automáticamente."
          },
          "response": []
        },
        {
          "name": "Verify Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.user) {",
                  "        pm.environment.set(\"userId\", jsonData.data.user.id);",
                  "        pm.environment.set(\"userRole\", jsonData.data.user.role);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-token"]
            },
            "description": "Verificar un ID token de Firebase (email/password o Google). Útil para validar tokens obtenidos del cliente."
          },
          "response": []
        },
